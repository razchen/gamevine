{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", ".env.*", "!.env*.example"],
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.*", "!**/*.spec.*", "!**/__tests__/**"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["NEXT_PUBLIC_*"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "DATABASE_URL",
        "PORT",
        "CORS_ORIGIN",
        "SENTRY_DSN",
        "AI_API_KEY",
        "AI_MODEL",
        "AI_BASE_URL",
        "POC_API_ENABLED",
        "POC_MAX_CONCURRENT_RUNS",
        "POC_RUNS_DIR",
        "POC_TEMPLATES_ROOT",
        "NEXT_PUBLIC_*",
        "NODE_ENV"
      ]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "test:cov": {
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false,
      "outputs": []
    }
  }
}

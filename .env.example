# Root .env.example — copy the relevant sections into each app's local `.env`
# (apps/api/.env and apps/web/.env.local). Both apps also have their own
# .env.example files; this file documents the full set in one place.

# -- Shared --------------------------------------------------------------------

NODE_ENV=development

# -- apps/api ------------------------------------------------------------------

# Port the NestJS server listens on (default 3001).
PORT=3001

# Local Postgres connection string. Create the database with:
#   createdb gamevine
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gamevine

# Origin(s) allowed to make browser requests to the API. Accepts a single
# origin or a comma-separated list (e.g. http://localhost:3000,https://app.example).
CORS_ORIGIN=http://localhost:3000

# Optional Sentry DSN for API error reporting. Leave empty to disable.
# SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>

# -- apps/web ------------------------------------------------------------------

# Base URL the web app uses to reach the API (browser-exposed, hence the
# NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_API_URL=http://localhost:3001

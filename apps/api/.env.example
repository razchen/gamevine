# NestJS API environment — copy to `.env` for local dev.

NODE_ENV=development
PORT=3001

# Connection string for the local Postgres database.
# Create it with: createdb gamevine
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gamevine

# Allowed origin(s) for browser requests from the web app. Single value or a
# comma-separated list (e.g. http://localhost:3000,https://app.example).
CORS_ORIGIN=http://localhost:3000

# Optional Sentry DSN for API error reporting. Leave empty to disable.
# SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>

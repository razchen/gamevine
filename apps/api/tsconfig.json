{
  "extends": "@gamevine/tsconfig/nestjs.json",
  "compilerOptions": {
    "outDir": "./dist",
    "tsBuildInfoFile": "./.tsbuildinfo.typecheck",
    "types": ["node", "jest"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "drizzle.config.ts"],
  "exclude": ["node_modules", "dist", ".turbo"]
}

# Next.js web environment — copy to `.env.local` for local dev.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Set to `1` to expose the internal design sandbox at `/design/*`. Leave unset
# in production; the sandbox is a pre-launch palette / surface preview and is
# hard-gated to 404 when this flag is anything other than `1`.
NEXT_PUBLIC_DESIGN_SANDBOX=1

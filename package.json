{
  "name": "gamevine",
  "version": "0.0.0",
  "private": true,
  "description": "Gamevine.ai monorepo — browser-based games & community-driven updates",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "preinstall": "only-allow pnpm",
    "postinstall": "simple-git-hooks",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@gamevine/web",
    "dev:api": "turbo run dev --filter=@gamevine/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier . --write --log-level warn",
    "format:check": "prettier . --check --log-level warn",
    "commitlint": "commitlint"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm commitlint --edit $1",
    "pre-push": "pnpm typecheck && pnpm lint && pnpm test && pnpm format:check"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md,mdc,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^22.10.5",
    "lint-staged": "^16.4.0",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.0"
  }
}
